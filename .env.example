# RADF HW1 — copy to .env and fill in. .env is git-ignored; never commit the key.

# Required: your OpenCode Zen API key (never hard-coded in source).
OPENCODE_API_KEY=sk-...

# Optional overrides. Defaults live in agentlib/core.py.
# OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Model ids. Defaults are gpt-5.4-nano / gpt-5.5 — set these only to override.
# Anything you pick here should also be priced in MODELS (agentlib/core.py), or
# estimate_cost() returns 0.0 for it. Note: gemini-* ids appear in Zen's /models
# listing but 400 on every call — see ARCHITECTURE.md decision #12.
# OPENCODE_CHEAP_MODEL=gpt-5.4-nano
# OPENCODE_STRONG_MODEL=gpt-5.5
